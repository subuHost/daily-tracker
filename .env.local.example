# Push Notifications (VAPID)
# Keys are generated via `npx web-push generate-vapid-keys`
# The private key + subject must also be set as Supabase Edge Function secrets for the `push-dispatcher` function.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your@email.com

# AI Providers
GEMINI_API_KEY=
FINNHUB_API_KEY=
OPENAI_API_KEY=        # optional server-side fallback
PERPLEXITY_API_KEY=    # optional server-side fallback

# Supabase Edge Function Secrets (set via Supabase Dashboard → Edge Functions → Secrets)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
